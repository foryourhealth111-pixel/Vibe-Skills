{
  "schema_version": 2,
  "package_id": "runtime-core",
  "summary": "Host-neutral runtime-core payload that can be installed without bundling the entire skill catalog into the runtime payload.",
  "profile_manifests": {
    "minimal": "config/runtime-core-packaging.minimal.json",
    "full": "config/runtime-core-packaging.full.json"
  },
  "catalog_packaging_manifest": "config/skill-catalog-packaging.json",
  "directories": [
    "skills",
    "commands",
    "config"
  ],
  "copy_directories": [
    {
      "source": "commands",
      "target": "commands"
    }
  ],
  "copy_files": [
    {
      "source": "config/upstream-lock.json",
      "target": "config/upstream-lock.json",
      "optional": false
    },
    {
      "source": "config/skills-lock.json",
      "target": "config/skills-lock.json",
      "optional": true
    }
  ],
  "exclude_bundled_skill_names": [
    "vibe"
  ],
  "canonical_vibe_payload": {
    "enabled": true,
    "target_relpath": "skills/vibe"
  }
}
