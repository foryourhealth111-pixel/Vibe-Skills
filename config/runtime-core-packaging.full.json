{
  "schema_version": 1,
  "package_id": "runtime-core-full",
  "profile": "full",
  "summary": "Runtime-core payload with the same governed runtime foundation as minimal; catalog installation is delegated to the default-full profile.",
  "runtime_profile": "core-default",
  "catalog_profile": "default-full",
  "directories": [
    "skills",
    "commands",
    "config"
  ],
  "copy_directories": [
    {
      "source": "commands",
      "target": "commands"
    }
  ],
  "copy_files": [
    {
      "source": "config/upstream-lock.json",
      "target": "config/upstream-lock.json",
      "optional": false
    },
    {
      "source": "config/skills-lock.json",
      "target": "config/skills-lock.json",
      "optional": true
    }
  ],
  "copy_bundled_skills": false,
  "bundled_skills_source": "bundled/skills",
  "skills_allowlist": [],
  "exclude_bundled_skill_names": [
    "vibe"
  ],
  "canonical_vibe_payload": {
    "enabled": true,
    "target_relpath": "skills/vibe"
  }
}
